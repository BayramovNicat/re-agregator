{
	"name": "redeal",
	"version": "1.0.0",
	"description": "Real estate deal-finding aggregator for the Azerbaijani (Baku) market",
	"type": "module",
	"scripts": {
		"dev": "bun run scripts/build.ts --watch & NODE_ENV=development bun --watch src/index.ts",
		"start": "bun run scripts/build.ts && bun src/index.ts",
		"build": "bun run scripts/build.ts",
		"typecheck": "tsc --noEmit && tsc -p frontend/tsconfig.json --noEmit && tsc -p tsconfig.tests.json --noEmit",
		"db:migrate": "prisma migrate deploy",
		"db:push": "prisma db push",
		"db:studio": "prisma studio",
		"lint": "biome lint",
		"format": "biome format --write",
		"check": "biome check --write",
		"test": "bun test",
		"test:e2e": "bunx playwright test",
		"update:active-mortgages": "bun scripts/update-active-mortgages.ts",
		"verify": "bun run typecheck && bun test && bun run test:e2e",
		"verify:db": "bun scripts/verify-db.ts"
	},
	"dependencies": {
		"@prisma/client": "^5.22.0",
		"clsx": "^2.1.1",
		"leaflet": "^1.9.4",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@playwright/test": "^1.57.0",
		"@tailwindcss/postcss": "^4.2.2",
		"@types/bun": "^1.3.13",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^22.10.2",
		"postcss": "^8.5.9",
		"prisma": "^5.22.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.7.2"
	}
}
